unit NumericText;

{$I Shared.inc}

interface

uses
  SysUtils;

function CreateInvariantFormatSettings: TFormatSettings;

// Uses each compiler's native RTL name for parsing an unsigned 64-bit value.
function TryTextToUInt64(const AText: string; out AValue: UInt64): Boolean;

// Converts a grammar-valid decimal numeral to the nearest binary64 value using
// round-to-nearest, ties-to-even. Invalid decimal text returns NaN. Callers
// with a narrower grammar (source literals, JSON, TOML) validate that grammar
// before delegating the decimal value conversion here.
function DecimalTextToNumber(const AText: string): Double;

// ES2026 Number::toString for radix 10. The result is the shortest decimal
// representation that round-trips to AValue, laid out using ECMAScript's
// fixed/scientific notation thresholds.
function NumberToString(const AValue: Double): string;

// Converts a String to a Number following the ECMA-262 StringToNumber
// abstract operation and the StringNumericLiteral grammar. Returns a raw
// Double (NaN for any input that is not a StringNumericLiteral) and performs
// no value-object allocation, so runtime primitive coercion and compile-time
// constant folding can share a single implementation instead of each keeping
// its own partial parser.
function StringToNumber(const AText: string): Double;

