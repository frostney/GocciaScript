function CreateInvariantFormatSettings: TFormatSettings;
begin
  {$IFDEF FPC}
  Result := DefaultFormatSettings;
  {$ELSE}
  Result := TFormatSettings.Invariant;
  {$ENDIF}
  Result.DecimalSeparator := '.';
end;

function TryTextToUInt64(const AText: string; out AValue: UInt64): Boolean;
begin
  {$IFDEF FPC}
  Result := TryStrToQWord(AText, AValue);
  {$ELSE}
  Result := TryStrToUInt64(AText, AValue);
  {$ENDIF}
end;

