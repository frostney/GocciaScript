{
  // GocciaScript markdownlint configuration
  "config": {
    "default": true,

    // Line length — disabled because docs have long tables and links
    "MD013": false,

    // Allow multiple headings with the same content (common in large docs)
    "MD024": { "siblings_only": true },

    // Allow trailing punctuation in headings (e.g., "Bug A: ...")
    "MD026": false,

    // Allow inline HTML (used sparingly in some docs)
    "MD033": false,

    // Allow bare URLs (used in code comments)
    "MD034": false,

    // Allow emphasis as heading (italic subtitles like *For contributors...*)
    "MD036": false,

    // First line should be a top-level heading
    "MD041": true,

    // Table column style — disabled; our tables use compact style without padding
    "MD055": false,
    "MD056": false,
    "MD060": false
  },
  "ignores": [
    "node_modules",
    "**/node_modules/**",
    "CHANGELOG.md",
    ".agents/skills/**",
    "website/content/docs/**",
    // Claude Code @-include shim files — single-line `@OTHER.md` directives
    // that aren't real markdown.
    "website/CLAUDE.md"
  ],
  "globs": [
    "**/*.md"
  ]
}
